# Environment settings (development, testing, production)
APP_ENV=development

# LLM provider select (fake, openai)
LLM_PROVIDER=fake

# OpenAI Configuration
# OPENAI_API_KEY is required only when LLM_PROVIDER=openai (or APP_ENV=production)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Database Configuration
DATABASE_URL=sqlite:///./toeic.db
